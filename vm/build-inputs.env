# Pinned top-level inputs for the in-browser Linux VM build.
#
# Update this file only in a dedicated dependency-refresh change. Exact package
# versions intentionally make a removed or changed upstream artifact fail the
# build instead of silently selecting a new top-level version. The complete
# installed runtime closure is checked against apk-runtime.lock. Alpine's live
# repositories and generated file metadata still mean the rootfs is not
# byte-for-byte reproducible, so published bytes also carry reviewed checksums.

# linux/386 manifest from the official alpine:3.19 image index.
ALPINE_IMAGE=alpine@sha256:45470a1b6b2bb3c200494c9caff4796ad4379e8a9090d4f664cf7f6c5052cbd6

# TinyCC source revision embedded by build-rootfs.sh.
TCC_COMMIT=b39da9f6fa7e32c7c8bf6f0bb093fa6331fa5cbb

# Alpine v3.19 x86 package versions used to construct the root filesystem.
APK_BASH_VERSION=5.2.21-r0
APK_COREUTILS_VERSION=9.4-r2
APK_DIFFUTILS_VERSION=3.10-r0
APK_FINDUTILS_VERSION=4.9.0-r5
APK_GREP_VERSION=3.11-r0
APK_SED_VERSION=4.9-r2
APK_GAWK_VERSION=5.3.0-r1
APK_GIT_VERSION=2.43.7-r0
APK_MAKE_VERSION=4.4.1-r2
APK_NANO_VERSION=7.2-r1
APK_LESS_VERSION=643-r2
APK_FILE_VERSION=5.45-r1
APK_TREE_VERSION=2.1.1-r0
APK_MUSL_DEV_VERSION=1.2.4_git20230717-r6
APK_GCC_VERSION=13.2.1_git20231014-r0
APK_LINUX_VIRT_VERSION=6.6.142-r0

# Repository-owned v86 artifacts. setup.sh verifies these before building.
V86_LIBV86_SHA256=3a64f4dfef4f6ada802aa38bd05b1caf534fa3ca085c6ea297673a11d13b93df
V86_WASM_SHA256=d6bffdfc35f81bdc806245232463a617fb60ad8129c72f5c534b4fb5198d49e7
V86_SEABIOS_SHA256=73e3f359102e3a9982c35fce98eb7cd08f18303ac7f1ba6ebfbe6cdc1c244d98
V86_VGABIOS_SHA256=a4bc0d80cc3ca028c73dafa8fee396b8d054ce87ebd8abfbd31b06b437607880
