#!/bin/bash
# Simulated gcc for SEBook Makefile tutorial

output="a.out"
compile_only=false
inputs=()

while [[ $# -gt 0 ]]; do
  case $1 in
    -o) output="$2"; shift 2 ;;
    -c) compile_only=true; shift ;;
    -Wall|-std=*|-g|-O*) shift ;;
    *)
      [[ ! "$1" =~ ^- ]] && inputs+=("$1")
      shift
      ;;
  esac
done

if [ ${#inputs[@]} -eq 0 ]; then
  echo "gcc: fatal error: no input files" >&2
  echo "compilation terminated." >&2
  exit 1
fi

# Check a single .c file for syntax errors and print gcc-style diagnostics.
# Currently detects: return statement missing a trailing semicolon.
# Returns 1 if any errors were found.
check_c_syntax() {
  local file="$1"
  local linenum=0
  local had_error=0
  local func_name=""

  while IFS= read -r line || [[ -n "$line" ]]; do
    ((linenum++))

    # Strip // line comments to get the code portion, then trim trailing whitespace
    local code="${line%%//*}"
    local trimmed="${code%"${code##*[![:space:]]}"}"

    # Track the enclosing function name (last word before '(' on a line ending in '{')
    if [[ "$trimmed" =~ \)\{[[:space:]]*$ || "$trimmed" =~ \)[[:space:]]+\{[[:space:]]*$ ]]; then
      local m
      m=$(echo "$trimmed" | grep -oP '\b\w+(?=\s*\()' | tail -1)
      [[ -n "$m" ]] && func_name="$m"
    fi

    # Detect a return expression with no trailing semicolon.
    # A multi-line expression ending in an operator is not flagged (ends in +, -, *, /, etc.)
    if [[ "$trimmed" =~ ^[[:space:]]*return[[:space:]]+ ]] && \
       [[ ! "$trimmed" =~ \;[[:space:]]*$ ]] && \
       [[ ! "$trimmed" =~ [+\-\*/,\(\\][[:space:]]*$ ]]; then
      local col=$(( ${#trimmed} + 2 ))
      local fn="${func_name:-<unknown>}"
      printf "%s: In function '%s':\n" "$file" "$fn" >&2
      printf "%s:%d:%d: error: expected ';' before '}' token\n" \
        "$file" "$linenum" "$col" >&2
      printf " %4d | %s\n" "$linenum" "$line" >&2
      local spaces
      spaces=$(printf '%*s' "$(( col - 1 ))" '')
      printf "      | %s^\n" "$spaces" >&2
      printf "      | %s;\n" "$spaces" >&2
      had_error=1
    fi
  done < "$file"

  return "$had_error"
}

# Validate all .c inputs before producing any output
has_error=0
for f in "${inputs[@]}"; do
  if [ ! -f "$f" ]; then
    echo "gcc: error: $f: No such file or directory" >&2
    exit 1
  fi
  if [[ "$f" == *.c ]]; then
    check_c_syntax "$f" || has_error=1
  fi
done

[ "$has_error" -ne 0 ] && exit 1

if $compile_only; then
  for f in "${inputs[@]}"; do
    # Honour an explicit -o flag when compiling a single file
    if [ "$output" != "a.out" ] && [ "${#inputs[@]}" -eq 1 ]; then
      cp "$f" "$output" 2>/dev/null
    else
      target="${f%.*}.o"
      cp "$f" "$target" 2>/dev/null
    fi
  done
else
  cat "${inputs[@]}" > "$output" 2>/dev/null
  chmod +x "$output" 2>/dev/null
fi
sleep 1
